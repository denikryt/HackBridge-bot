DISCORD_TOKEN=

# MongoDB (use host.docker.internal inside Docker; localhost for local dev)
MONGO_URI=mongodb://hackbridge_user:password@host.docker.internal:27017/hackbridge?authSource=admin
MONGO_DB=hackbridge

AVATAR_COLLECTION_NAME=user_avatars_base

# Logging
LOG_FILE=logs/hackbridge_bot.log
LOG_LEVEL=DEBUG

# Backward-compatible aliases used by the current codebase
token=
avatar_collection_name=user_avatars_base
